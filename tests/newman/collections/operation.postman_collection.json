{
  "info": {
    "_postman_id": "008d5ee8-6ae6-4288-8cea-f8039ab889fb",
    "name": "kacho-nlb / newman / operation",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('runId') || pm.environment.get('runId') === '') {",
          "  const t = Date.now().toString(36);",
          "  const r = Math.floor(Math.random() * 1e9).toString(36);",
          "  pm.environment.set('runId', (t + r).replace(/[^a-z0-9]/g, '').slice(-10));",
          "}",
          "pm.environment.set('_suiteProjectId', pm.environment.get('existingProjectId'));",
          "pm.environment.set('_suiteProjectCrossId', pm.environment.get('existingProjectCrossId'));",
          "pm.environment.set('_suiteRegionId', pm.environment.get('existingRegionId'));",
          "pm.environment.set('_suiteRegionAltId', pm.environment.get('existingRegionAltId'));",
          "// Default auth: project-editor JWT on project A (sufficient for most happy-path steps).",
          "// Per-step auth= overrides via _auth_pre_script.",
          "const __defaultJwt = pm.environment.get('jwtProjectEditorA') || pm.variables.get('jwtProjectEditorA') || '';",
          "if (__defaultJwt && !pm.request.headers.has('Authorization')) {",
          "  pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + __defaultJwt});",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "OP-GET-CRUD-IN-FLIGHT — Get just-created operation eventually polls to done=true",
      "description": "class:CRUD | priority:P0",
      "item": [
        {
          "name": "trigger-create",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/nlb/v1/networkLoadBalancers",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "nlb",
                "v1",
                "networkLoadBalancers"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"projectId\": \"{{_suiteProjectId}}\", \"regionId\": \"{{_suiteRegionId}}\", \"name\": \"opget-inflight-{{runId}}\", \"type\": \"EXTERNAL\", \"v4Source\": {\"public\": {}}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "try {",
                  "  const j = pm.response.json();",
                  "  const v = (j.id);",
                  "  if (v !== undefined && v !== null) pm.environment.set('opId', String(v));",
                  "} catch (e) {}",
                  "try {",
                  "  const j = pm.response.json();",
                  "  const v = (j.metadata && j.metadata.networkLoadBalancerId);",
                  "  if (v !== undefined && v !== null) pm.environment.set('nlbId', String(v));",
                  "} catch (e) {}",
                  "pm.test('done initially false or true', () => {  const j = pm.response.json();  pm.expect(typeof j.done).to.eql('boolean');});"
                ]
              }
            }
          ]
        },
        {
          "name": "get-op-immediate",
          "request": {
            "method": "GET",
